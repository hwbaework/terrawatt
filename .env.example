# Mapbox 공개 액세스 토큰 (pk.*) — https://account.mapbox.com/access-tokens/
# 배포 도메인으로 URL 제한을 걸어두는 것을 권장
VITE_MAPBOX_TOKEN=pk.your_token_here

# 카카오 로컬(주소 검색) REST API 키 — https://developers.kakao.com → 내 애플리케이션 → REST API 키
# 없으면 주소 검색이 Mapbox 지오코딩으로 동작(한국 주소 정확도 낮음)
VITE_KAKAO_REST_KEY=your_kakao_rest_key_here

# 발전소 실시간 데이터(LASEE) 백엔드 — energy-frontend의 API_BACKEND_URL과 동일
# 미설정 시 마커가 "실시간 대기"로 표시됨
VITE_ENERGY_API_BASE=https://your-energy-backend
